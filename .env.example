APP_TITLE=Easy_Ecom
ALLOW_BACKORDER=false

# Bootstrap-only admin seed (used by init_data, not ongoing auth source).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
CREATE_DEFAULT_CLIENT=false

# Canonical runtime storage: AWS RDS Postgres.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<rds-endpoint>:5432/<db_name>
POSTGRES_ECHO=false
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# API/session settings
SESSION_SECRET=change-me-in-production
SESSION_COOKIE_NAME=easy_ecom_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=none

# Frontend origins (Amplify domains or custom domains)
CORS_ALLOW_ORIGINS=https://main.<your-amplify-id>.amplifyapp.com
BCRYPT_ROUNDS=12

# AI customer communication
AI_PROVIDER=nvidia
AI_TIMEOUT_SECONDS=45
NVIDIA_API_KEY=
NVIDIA_MODEL=google/gemma-4-31b-it
NVIDIA_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_PRIMARY_TIMEOUT_SECONDS=8
NVIDIA_FALLBACK_TIMEOUT_SECONDS=25
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Self-serve billing
APP_BASE_URL=https://easy-ecom.online
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PRODUCT_GROWTH_ID=
PAYPAL_PRODUCT_SCALE_ID=
PAYPAL_PLAN_GROWTH_MONTHLY=
PAYPAL_PLAN_SCALE_MONTHLY=
PAYPAL_PRICE_GROWTH_MONTHLY_AMOUNT=
PAYPAL_PRICE_SCALE_MONTHLY_AMOUNT=

# Product media pipeline
AWS_REGION=
PRODUCT_MEDIA_S3_BUCKET=
PRODUCT_MEDIA_S3_PREFIX=clients
PRODUCT_MEDIA_STAGED_TTL_HOURS=24
