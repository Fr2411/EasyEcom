<+>APP_TITLE=Easy_Ecom\nALLOW_BACKORDER=false\n\n# Bootstrap-only admin seed (used by init_data, not ongoing auth source).\nSUPER_ADMIN_EMAIL=\nSUPER_ADMIN_PASSWORD=\nCREATE_DEFAULT_CLIENT=false\n\n# Canonical runtime storage: AWS RDS Postgres.\nSTORAGE_BACKEND=postgres\nDATABASE_URL=postgresql+psycopg://<user>:<password>@<rds-endpoint>:5432/<db_name>\nPOSTGRES_ECHO=false\nPOSTGRES_POOL_SIZE=5\nPOSTGRES_MAX_OVERFLOW=10\n\n# API/session settings\nSESSION_SECRET=change-me-in-production\nSESSION_COOKIE_NAME=easy_ecom_session\nSESSION_COOKIE_SECURE=true\nSESSION_COOKIE_DOMAIN=\nSESSION_COOKIE_SAMESITE=none\n\n# Frontend origins (Amplify domains or custom domains)\nCORS_ALLOW_ORIGINS=https://main.<your-amplify-id>.amplifyapp.com\nBCRYPT_ROUNDS=12\n
